#!/bin/bash
# Pre-commit hook — repo-tracked, activated via `git config core.hooksPath .githooks`
#
# Layers (in order):
#   1. Cluster Secret values — pull every Kubernetes Secret (excluding k8s-internal
#      types like service-account-token / tls / helm releases) and grep staged
#      files for any decoded value ≥8 chars. Catches domain leaks, passwords,
#      API tokens, and anything else stored in-cluster.
#      Warns and continues if kubectl is unreachable.
#   2. Unencrypted *.sops.yaml — block commits of files matching .sops.yaml
#      creation_rules paths that lack the top-level `sops:` block.
#   3. Pattern-based credential detectors — API keys, AWS keys, JWTs, GitHub
#      tokens, private keys, generic password=... patterns, DB connection strings.

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
DIM='\033[2m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$STAGED_FILES" ] && exit 0

VIOLATIONS=$(mktemp)
SECRETS_FOUND=0
trap 'rm -f "$VIOLATIONS" "$LITERALS"' EXIT

echo "🔍 Scanning staged files for secrets..."

# ───────────────────────────────────────────────────────────────────
# Layer 1: pull literals from all cluster Secrets (cached 10 min)
# ───────────────────────────────────────────────────────────────────
LITERALS=$(mktemp)
CACHE="${TMPDIR:-/tmp}/cberg-precommit-literals.cache"
CACHE_AGE_SEC=600

# Resolve kubectl: try PATH directly, then mise shims, then `mise exec --`.
KUBECTL=""
if command -v kubectl >/dev/null 2>&1; then
    KUBECTL="kubectl"
elif [ -x "$HOME/.local/share/mise/shims/kubectl" ]; then
    KUBECTL="$HOME/.local/share/mise/shims/kubectl"
elif command -v mise >/dev/null 2>&1; then
    KUBECTL="mise exec -- kubectl"
fi

if [ -f "$CACHE" ] && [ $(($(date +%s) - $(stat -f %m "$CACHE" 2>/dev/null || stat -c %Y "$CACHE" 2>/dev/null || echo 0))) -lt $CACHE_AGE_SEC ]; then
    cp "$CACHE" "$LITERALS"
    echo -e "${DIM}  · using cached cluster-secret literals ($(wc -l < "$LITERALS" | tr -d ' ') strings, refresh in $((CACHE_AGE_SEC - $(($(date +%s) - $(stat -f %m "$CACHE" 2>/dev/null || stat -c %Y "$CACHE" 2>/dev/null))))) s)${NC}"
elif [ -n "$KUBECTL" ] && $KUBECTL get ns kube-system >/dev/null 2>&1; then
    PY_SCRIPT=$(mktemp)
    cat > "$PY_SCRIPT" <<'PY'
import sys, json, base64, re
out_path = sys.argv[1]
SKIP_TYPES = {
    "kubernetes.io/service-account-token",
    "kubernetes.io/tls",
    "kubernetes.io/dockerconfigjson",
    "kubernetes.io/dockercfg",
    "bootstrap.kubernetes.io/token",
    "helm.sh/release.v1",
}
# Whitelist Secret keys whose values are public identifiers, not credentials.
# Decoded values from these keys are *never* added to the literals scan list,
# because flagging them creates false positives the moment the same identifier
# (a GitHub org name, an OCI image coordinate, a timezone string) shows up in
# any committed manifest.
#
# Selection rule: a key qualifies only if its value is, by convention, public
# coordinates that may legitimately appear verbatim in YAML manifests. Adding
# a key here means "if a real secret is ever stored under this key it will
# slip past Layer 1" — so we keep the list narrow and identifier-only.
#
# Current entries:
#   TIMEZONE, TZ, tz, timezone — IANA tz strings (Europe/Berlin etc.)
#   ca.crt                     — X.509 CA bundles (handled by BEGIN CERT skip too)
#   username                   — basic-auth / GHCR / git pull username (e.g.
#                                an org or repo-owner handle); the password
#                                is the actual secret and is in a different
#                                key (`password`, `token`, `.dockerconfigjson`)
#   repository, repo           — git/OCI repository coordinates
#   org, organization          — GitHub/GitLab org slugs
#   image                      — fully qualified image references
#   OPENAI_URI_BASE,           — LAN Ollama/OpenAI-compatible endpoint URL.
#   OPENAI_BASE,                 Shared infra coordinate (e.g.
#   OLLAMA_BASE,                 http://192.168.30.111:11434/v1) referenced
#   OLLAMA_BASE_URL              verbatim in helmreleases and CLAUDE.md. The
#                                companion API key lives in OPENAI_ACCESS_TOKEN
#                                / OPENAI_API_KEY, which are scanned normally.
#   TELEGRAM_ALLOWED_USERS      — comma-separated public Telegram user IDs
#                                (numeric chat IDs are public — visible to
#                                anyone the user has messaged). Bot token
#                                is in TELEGRAM_BOT_TOKEN, scanned normally.
#   SECRET_ICLOUD_USERNAME,     — usernames/emails for paired-credential
#   *_USERNAME                    accounts. Passwords live in the matching
#                                _PASSWORD / _TOKEN keys, scanned normally.
SKIP_KEY_NAMES = {
    "TIMEZONE", "TZ", "tz", "timezone", "ca.crt",
    "username", "repository", "repo", "org", "organization", "image",
    "OPENAI_URI_BASE", "OPENAI_BASE", "OLLAMA_BASE", "OLLAMA_BASE_URL",
    "TELEGRAM_ALLOWED_USERS", "SECRET_ICLOUD_USERNAME",
    "NEXTCLOUD_USERNAME",
}
# Pure-lowercase dictionary-like words (no digits, no special chars) — these
# overlap with common technical terms (postgres, authentik, placeholder, etc.)
# and cause false positives. Real secrets have entropy markers (digits, case,
# special chars). Trade-off: a weak all-lowercase password would slip through.
DICTIONARY_WORD = re.compile(r"^[a-z]{1,15}$")
# DNS-1123-style Kubernetes resource names (lowercase + digits + hyphens,
# must start with a letter, ≤30 chars). Examples we have actually hit as
# false positives: `superset-postgresql` (Helm release name surfaced in a
# Secret's value), `wazuh-wui` (the Wazuh dashboard's API user — username
# is in a Secret but the password is the actual credential). These names
# legitimately appear verbatim in manifests, docs, and AR-* records.
# Same trade-off as DICTIONARY_WORD: a weak hyphenated lowercase password
# (e.g. "correct-horse-battery") would also be filtered. Cap at 30 chars
# so longer high-entropy hyphenated tokens still get scanned.
K8S_NAME = re.compile(r"^[a-z][a-z0-9-]{0,29}$")
# Pure IPv4/IPv6 literals — Secret values that are just an IP address are
# config endpoints (NAS host, DB host, SMTP server, etc.), not credentials,
# and routinely show up in StorageClass YAML, infra docs, network SOPs.
# Skip them so they don't false-positive every CIFS/network change.
IPV4 = re.compile(r"^\d{1,3}(?:\.\d{1,3}){3}$")
IPV6 = re.compile(r"^[0-9a-fA-F:]+$")
# OCI-style image/model tags (e.g. `gemma4:26b`, `nginx:1.25-alpine`).
# These often live in cluster-secrets as shared config (the cluster's Ollama
# model, default image versions) and are referenced from manifests by name —
# not secrets, even though they're in a Secret object. Cap length to prevent
# masking real `key:longvalue` patterns.
OCI_TAG = re.compile(r"^[a-zA-Z][a-zA-Z0-9._-]*:[a-zA-Z0-9._-]+$")
# Kubernetes in-cluster service DNS, optionally with a port — e.g.
# `postgresql.databases.svc.cluster.local` or `prometheus-pushgateway.monitoring.svc:9091`.
# Like the IPv4/IPv6 skip above, these are config endpoints (DB host, broker,
# pushgateway), not credentials, and legitimately appear verbatim in manifests
# (PG_HOST, *_URL env values). A Secret value that is *only* a service FQDN
# (e.g. openclaw-secret/PELLET_PG_HOST) was false-positiving every manifest
# that references the same service. Anchored on the mandatory `.svc` label so
# no real high-entropy secret can match.
SVC_DNS = re.compile(r"^[a-z][a-z0-9-]*(\.[a-z][a-z0-9-]*)*\.svc(\.cluster\.local)?(:\d{1,5})?$")
literals = set()
data = json.load(sys.stdin)
for s in data.get("items", []):
    if s.get("type") in SKIP_TYPES:
        continue
    for k, v in (s.get("data") or {}).items():
        if k in SKIP_KEY_NAMES:
            continue
        try:
            decoded = base64.b64decode(v).decode("utf-8", errors="ignore")
        except Exception:
            continue
        if len(decoded) < 8 or len(decoded) > 256:
            continue
        if "BEGIN " in decoded and "PRIVATE KEY" in decoded:
            continue
        if "BEGIN CERTIFICATE" in decoded:
            continue
        if "\n" in decoded:
            continue
        if DICTIONARY_WORD.match(decoded):
            continue
        if K8S_NAME.match(decoded):
            continue
        if IPV4.match(decoded):
            continue
        if len(decoded) >= 6 and IPV6.match(decoded) and ":" in decoded:
            continue
        if len(decoded) <= 30 and OCI_TAG.match(decoded):
            continue
        if SVC_DNS.match(decoded):
            continue
        literals.add(decoded)
with open(out_path, "w") as f:
    for lit in literals:
        f.write(lit + "\n")
PY
    $KUBECTL get secrets -A -o json 2>/dev/null | python3 "$PY_SCRIPT" "$LITERALS" || true
    rm -f "$PY_SCRIPT"
    if [ -s "$LITERALS" ]; then
        cp "$LITERALS" "$CACHE"
        echo -e "${DIM}  · loaded $(wc -l < "$LITERALS" | tr -d ' ') secret literals from cluster${NC}"
    fi
else
    echo -e "${YELLOW}  ⚠ kubectl unreachable — skipping Layer 1 (cluster Secret value scan).${NC}"
    echo -e "${YELLOW}    Layers 2 + 3 still active. Re-run after VPN/kubeconfig is restored.${NC}"
fi

# ───────────────────────────────────────────────────────────────────
# Layer 2: unencrypted *.sops.yaml
# ───────────────────────────────────────────────────────────────────
for file in $STAGED_FILES; do
    case "$file" in
        kubernetes/*.sops.yaml|talos/*.sops.yaml|kubernetes/**/*.sops.yaml|talos/**/*.sops.yaml)
            content=$(git show ":$file" 2>/dev/null || true)
            if ! echo "$content" | grep -qE '^sops:'; then
                echo -e "${RED}✗${NC} $file" >> "$VIOLATIONS"
                echo -e "  - Unencrypted .sops.yaml file (missing top-level 'sops:' block)\n" >> "$VIOLATIONS"
                SECRETS_FOUND=1
            fi
            ;;
    esac
done

# ───────────────────────────────────────────────────────────────────
# Helper: scan a single file
# ───────────────────────────────────────────────────────────────────
check_file() {
    local file=$1
    local violations=""

    # Skip binary
    file "$file" 2>/dev/null | grep -q text || return 0

    local content
    content=$(git show ":$file" 2>/dev/null) || return 0

    # Layer 1: literal match against any cluster-secret value
    if [ -s "$LITERALS" ]; then
        local hit
        hit=$(echo "$content" | grep -F -f "$LITERALS" -m 1 || true)
        if [ -n "$hit" ]; then
            violations="${violations}  - Cluster-Secret value literal found in file (rotate if real)\n"
        fi
    fi

    # Layer 3: pattern-based detectors
    echo "$content" | grep -qE '(api[_-]?key|apikey)["\s:=]+[A-Za-z0-9]{20,}'      && violations="${violations}  - API key pattern\n"
    echo "$content" | grep -qE 'AKIA[0-9A-Z]{16}'                                  && violations="${violations}  - AWS access key\n"
    echo "$content" | grep -qE '(bearer|token)["\s:=]+[A-Za-z0-9_\-]{20,}'         && violations="${violations}  - Authentication token\n"
    echo "$content" | grep -qE 'BEGIN (RSA|DSA|EC|OPENSSH|PGP) PRIVATE KEY'        && violations="${violations}  - Private key\n"
    echo "$content" | grep -qE '(postgresql|mysql|mongodb)://[^:]+:[^@]+@'         && violations="${violations}  - DB connection string with creds\n"
    echo "$content" | grep -qE 'gh[pousr]_[A-Za-z0-9]{36,}'                        && violations="${violations}  - GitHub token\n"
    echo "$content" | grep -qE 'eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}\.[A-Za-z0-9_-]{10,}' && violations="${violations}  - JWT token\n"
    echo "$content" | grep -qiE '(secret|credential|auth)["\s:=]+[A-Za-z0-9+/=]{32,}' && violations="${violations}  - Generic secret\n"

    # Password patterns — guard against false-positives (templates, examples, ${VAR})
    if echo "$content" | grep -qE '(password|passwd)["\s:=]+[^"\s]{8,}'; then
        if ! echo "$content" | grep -qE '(example|sample|placeholder|your-password|CHANGEME|\$\{|\$\(\)|<[A-Z_]+>)'; then
            violations="${violations}  - Password pattern\n"
        fi
    fi

    if [ -n "$violations" ]; then
        echo -e "${RED}✗${NC} $file" >> "$VIOLATIONS"
        echo -e "$violations" >> "$VIOLATIONS"
        SECRETS_FOUND=1
    fi
}

for file in $STAGED_FILES; do
    [ -f "$file" ] && check_file "$file"
done

# ───────────────────────────────────────────────────────────────────
# Result
# ───────────────────────────────────────────────────────────────────
if [ $SECRETS_FOUND -eq 1 ]; then
    echo
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${RED}COMMIT BLOCKED: Secrets detected in staged files${NC}"
    echo -e "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    cat "$VIOLATIONS"
    echo
    echo -e "${YELLOW}For sensitive configuration: use SOPS-encrypted files or reference cluster Secrets via env vars.${NC}"
    echo -e "${YELLOW}If this is a false positive: bypass with --no-verify (and you'd better be sure).${NC}"
    exit 1
else
    echo -e "${GREEN}✅ No secrets detected in staged files${NC}"
    exit 0
fi
