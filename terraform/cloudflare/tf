#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")"
REPO_ROOT="$(git -C "$(dirname "$0")" rev-parse --show-toplevel)"
SOPS=$(command -v sops 2>/dev/null || echo "$HOME/.local/share/mise/shims/sops")

export TF_VAR_cloudflare_api_token=$(
  "$SOPS" -d "$REPO_ROOT/kubernetes/apps/network/external/cloudflared/cf-terraform-token.sops.yaml" \
  | python3 -c "import sys,yaml; print(yaml.safe_load(sys.stdin)['stringData']['api-token'])")

# Resolve zone_id from domain name (provider v5 data source requires zone_id directly)
_domain=$(
  "$SOPS" -d "$REPO_ROOT/kubernetes/flux/components/common/cluster-secrets.sops.yaml" \
  | python3 -c "import sys,yaml; print(yaml.safe_load(sys.stdin)['stringData']['SECRET_DOMAIN'])")

export TF_VAR_zone_id=$(
  curl -sf "https://api.cloudflare.com/client/v4/zones?name=$_domain" \
    -H "Authorization: Bearer $TF_VAR_cloudflare_api_token" \
  | python3 -c "import sys,json; print(json.load(sys.stdin)['result'][0]['id'])")

export KUBECONFIG="$HOME/.kube/config"
exec terraform "$@"
